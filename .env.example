# Server
NODE_ENV=development
PORT=5001

# Master DB (platform data only)
MASTER_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/inflix_master
MASTER_DB_NAME=inflix_master

# Tenant DBs on same cluster: dbName = TENANT_DB_PREFIX + tenantId
TENANT_DB_PREFIX=tenant_

# Tenant subdomain URL: https://<subdomain>.TENANT_URL_DOMAIN
TENANT_URL_DOMAIN=inflix.uk

# Platform auth (JWT for platform console; 8–12h recommended)
JWT_SECRET=your_jwt_secret_change_in_production
JWT_EXPIRE=7d
PLATFORM_JWT_SECRET=your_platform_jwt_secret_change_in_production
PLATFORM_JWT_EXPIRE=8h

# Tenant app APIs: shared secret for entitlements + events (not platform login)
PLATFORM_SHARED_SECRET=your_shared_secret_long_random_string

# Optional: allowlist of emails that can access platform console (comma-separated)
PLATFORM_ADMIN_EMAILS=

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# CORS (platform frontend origin; comma-separated for multiple)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
